{
  "$description": "Tokens CSS do Nativo que nao mapeiam 1:1 para Figma Variables.",
  "effect": {
    "shadow": {
      "none": {
        "$value": "none",
        "$type": "string",
        "$description": "--shadow-none"
      },
      "xs": {
        "$value": "0 1px 2px rgba(0, 0, 0, 0.04)",
        "$type": "string",
        "$description": "--shadow-xs"
      },
      "sm": {
        "$value": "0 1px 3px rgba(0, 0, 0, 0.05)",
        "$type": "string",
        "$description": "--shadow-sm"
      },
      "md": {
        "$value": "0 2px 6px rgba(0, 0, 0, 0.06)",
        "$type": "string",
        "$description": "--shadow-md"
      },
      "lg": {
        "$value": "0 4px 12px rgba(0, 0, 0, 0.07)",
        "$type": "string",
        "$description": "--shadow-lg"
      },
      "xl": {
        "$value": "0 8px 20px rgba(0, 0, 0, 0.08)",
        "$type": "string",
        "$description": "--shadow-xl"
      },
      "2xl": {
        "$value": "0 12px 32px rgba(0, 0, 0, 0.1)",
        "$type": "string",
        "$description": "--shadow-2xl"
      },
      "inner": {
        "$value": "inset 0 2px 4px rgba(0, 0, 0, 0.04)",
        "$type": "string",
        "$description": "--shadow-inner"
      },
      "focus": {
        "$value": "0 0 0 2px #28640f",
        "$type": "string",
        "$description": "--shadow-focus"
      },
      "focus-error": {
        "$value": "0 0 0 2px #c83b10",
        "$type": "string",
        "$description": "--shadow-focus-error"
      }
    }
  },
  "transition": {
    "fast": {
      "$value": "all 100ms cubic-bezier(0, 0, 0.2, 1)",
      "$type": "string",
      "$description": "--transition-fast"
    },
    "base": {
      "$value": "all 200ms cubic-bezier(0, 0, 0.2, 1)",
      "$type": "string",
      "$description": "--transition-base"
    },
    "slow": {
      "$value": "all 300ms cubic-bezier(0, 0, 0.2, 1)",
      "$type": "string",
      "$description": "--transition-slow"
    },
    "colors": {
      "$value": "color 200ms cubic-bezier(0, 0, 0.2, 1), background-color 200ms cubic-bezier(0, 0, 0.2, 1), border-color 200ms cubic-bezier(0, 0, 0.2, 1), box-shadow 200ms cubic-bezier(0, 0, 0.2, 1)",
      "$type": "string",
      "$description": "--transition-colors"
    }
  }
}
